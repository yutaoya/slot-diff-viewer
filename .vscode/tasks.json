{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Start Chrome Remote Debug (9222)",
      "type": "process",
      "command": "powershell.exe",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
        "-File",
        "${workspaceFolder}\\.vscode\\start-browser-debug.ps1",
        "-Browser",
        "chrome",
        "-Port",
        "9222",
        "-Url",
        "http://localhost:3000"
      ],
      "problemMatcher": []
    },
    {
